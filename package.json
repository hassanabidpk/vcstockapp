{
  "name": "vc-stocks-web-app",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm run dev:api & pnpm run dev:web",
    "build": "pnpm --filter @vc/db generate && pnpm -r build",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @vc/db migrate:dev",
    "db:generate": "pnpm --filter @vc/db generate",
    "db:seed": "pnpm --filter @vc/db seed",
    "db:studio": "pnpm --filter @vc/db studio"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "prettier": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
